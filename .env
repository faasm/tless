TLESS_VERSION=3.0.1
TLESS_CLI_IMAGE=faasm/tless-cli-sim:3.0.1
TLESS_WORKER_IMAGE=faasm/tless-worker-sim:3.0.1

CPP_VERSION=0.1.6
CPP_CLI_IMAGE=faasm/cpp-sysroot:0.1.6

PYTHON_VERSION=0.1.1
PYTHON_CLI_IMAGE=faasm/cpython:0.1.1

COMPOSE_PROJECT_NAME=tless-dev

FAASM_BUILD_DIR=./dev/faasm/build

# These switch off dev mode by default, mounting local versions of directories
# into junk locations
FAASM_BUILD_MOUNT=/host_dev/build
FAASM_LOCAL_MOUNT=/host_dev/faasm-local

CONAN_CACHE_MOUNT_SOURCE=./dev/faasm/conan/
